# Copy to supabase/.env.local and set your real keys.
# Then: supabase functions serve analyze --env-file supabase/.env.local
#
# Note: SUPABASE_URL is automatically provided, don't set it here.
# Use SERVICE_ROLE_KEY (not SUPABASE_SERVICE_ROLE_KEY) - Supabase doesn't allow SUPABASE_ prefix.

SERVICE_ROLE_KEY=your_service_role_key_here
WORKER_URL=http://localhost:3001
STORAGE_BUCKET=videos
